# ─────────────────────────────────────────────────────────────────────────────
# AppraisalIQ — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=appraisaliq
POSTGRES_USER=appraisaliq
POSTGRES_PASSWORD=changeme_strong_password_here

# ── App ────────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_strong_random_secret_here
ENVIRONMENT=development   # development | production

# ── CORS ───────────────────────────────────────────────────────────────────────
# Local dev:
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
# Production (replace with your domain):
# CORS_ORIGINS=https://yourdomain.com

# ── File Upload ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── DigitalOcean (production only) ────────────────────────────────────────────
# DOMAIN=yourdomain.com
# DO_SPACES_KEY=your_spaces_key
# DO_SPACES_SECRET=your_spaces_secret
# DO_SPACES_BUCKET=appraisaliq-uploads
# DO_SPACES_REGION=nyc3
